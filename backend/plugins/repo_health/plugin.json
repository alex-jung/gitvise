{
  "id": "repo-health",
  "name": "Repository Health",
  "version": "1.0.0",
  "tier": "community",
  "description": "Tracks health scores for all repositories: README, license, branch protection, staleness.",
  "widgets": [
    {
      "id": "repo-health-score",
      "type": "stat-card",
      "title": "Org Health Score",
      "description": "Aggregated health score across all repositories. Shows trend and critical repo count.",
      "defaultSize": "1/3",
      "tier": "community",
      "config": {
        "threshold_warn": {
          "type": "number",
          "label": "Warning threshold (%)",
          "default": 60,
          "min": 0,
          "max": 100
        },
        "threshold_critical": {
          "type": "number",
          "label": "Critical threshold (%)",
          "default": 40,
          "min": 0,
          "max": 100
        },
        "time_range": {
          "type": "number",
          "label": "Lookback (days)",
          "default": 30,
          "min": 7,
          "max": 365,
          "maxCommunity": 90
        },
        "score_weighting": {
          "type": "boolean",
          "label": "Custom score weighting",
          "default": false,
          "tier": "pro"
        }
      }
    },
    {
      "id": "repo-health-table",
      "type": "table",
      "title": "Repository Health Details",
      "description": "Full repository list with health score, branch protection status, missing files and last activity.",
      "defaultSize": "2/3",
      "tier": "community",
      "config": {
        "page_size": {
          "type": "number",
          "label": "Rows per page",
          "default": 25,
          "min": 10,
          "max": 100
        },
        "show_archived": {
          "type": "boolean",
          "label": "Show archived repositories",
          "default": false
        }
      }
    }
  ],
  "defaultDashboard": {
    "name": "Repository Health",
    "layout": [
      { "widgetId": "repo-health-score", "width": "1/3" },
      { "widgetId": "repo-health-table", "width": "2/3" }
    ]
  },
  "ui": {
    "navItem": {
      "label": "Repositories",
      "icon": "◫",
      "path": "/repos",
      "order": 1
    }
  },
  "backend": {
    "syncHooks": ["onSchedule"],
    "syncModule": "plugins.repo_health.sync"
  },
  "license": {
    "required": false
  }
}
