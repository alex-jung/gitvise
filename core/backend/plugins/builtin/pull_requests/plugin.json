{
  "id": "pull-requests",
  "name": "Pull Requests & Issues",
  "version": "1.0.0",
  "tier": "community",
  "description": "Tracks open pull requests and issues across all org repositories: age, labels, draft status.",
  "widgets": [
    {
      "id": "prs-open-count",
      "type": "stat-card",
      "title": "Open Pull Requests",
      "defaultSize": "1/3",
      "tier": "community",
      "config": {
        "stale_days": {
          "type": "number",
          "label": "Stale threshold (days)",
          "default": 7,
          "min": 1,
          "max": 90
        }
      }
    },
    {
      "id": "issues-open-count",
      "type": "stat-card",
      "title": "Open Issues",
      "defaultSize": "1/3",
      "tier": "community",
      "config": {}
    },
    {
      "id": "prs-draft-ratio",
      "type": "pie-chart",
      "title": "PR Status",
      "defaultSize": "1/3",
      "tier": "community",
      "config": {}
    },
    {
      "id": "prs-age-distribution",
      "type": "bar-chart",
      "title": "PR Age Distribution",
      "defaultSize": "2/3",
      "tier": "community",
      "config": {}
    },
    {
      "id": "issues-by-label",
      "type": "bar-chart",
      "title": "Issues by Label",
      "defaultSize": "1/3",
      "tier": "community",
      "config": {
        "max_labels": {
          "type": "number",
          "label": "Max labels to show",
          "default": 8,
          "min": 3,
          "max": 20
        }
      }
    },
    {
      "id": "prs-stale-table",
      "type": "table",
      "title": "Stale Pull Requests",
      "defaultSize": "full",
      "tier": "community",
      "config": {
        "stale_days": {
          "type": "number",
          "label": "Stale threshold (days)",
          "default": 7,
          "min": 1,
          "max": 90
        },
        "page_size": {
          "type": "number",
          "label": "Rows per page",
          "default": 20,
          "min": 5,
          "max": 100
        }
      }
    }
  ],
  "defaultDashboard": {
    "name": "Pull Requests & Issues",
    "layout": [
      { "widgetId": "prs-open-count",       "width": "1/3" },
      { "widgetId": "issues-open-count",     "width": "1/3" },
      { "widgetId": "prs-draft-ratio",       "width": "1/3" },
      { "widgetId": "prs-age-distribution",  "width": "2/3" },
      { "widgetId": "issues-by-label",       "width": "1/3" },
      { "widgetId": "prs-stale-table",       "width": "full" }
    ]
  },
  "ui": {
    "navItem": {
      "label": "Pull Requests",
      "icon": "⌥",
      "path": "/pull-requests",
      "order": 2
    }
  },
  "backend": {
    "syncHooks": ["onSchedule"],
    "syncModule": "plugins.builtin.pull_requests.sync"
  },
  "license": {
    "required": false
  }
}
