{
  "id": "ci-cd",
  "name": "CI/CD & Actions",
  "version": "1.0.0",
  "tier": "community",
  "description": "Tracks GitHub Actions workflow runs: success rates, failures, duration trends.",
  "widgets": [
    {
      "id": "ci-status-summary",
      "type": "stat-card",
      "title": "CI Status",
      "description": "Overall CI success rate with total run counts and in-progress workflows.",
      "defaultSize": "1/3",
      "tier": "community",
      "config": {
        "days": {
          "type": "number",
          "label": "Lookback (days)",
          "default": 7,
          "min": 1,
          "max": 365,
          "maxCommunity": 90
        },
        "breakdown": {
          "type": "boolean",
          "label": "Breakdown by workflow",
          "default": false,
          "tier": "pro"
        }
      }
    },
    {
      "id": "ci-failing-workflows",
      "type": "table",
      "title": "Failing Workflows",
      "description": "Workflows with recent failures sorted by failure count. Helps pinpoint flaky pipelines.",
      "defaultSize": "2/3",
      "tier": "community",
      "config": {
        "days": {
          "type": "number",
          "label": "Lookback (days)",
          "default": 7,
          "min": 1,
          "max": 365,
          "maxCommunity": 90
        }
      }
    },
    {
      "id": "ci-duration-trend",
      "type": "line-chart",
      "title": "Avg Run Duration",
      "description": "Average workflow run duration over time. Identify slowdowns before they become blockers.",
      "defaultSize": "2/3",
      "tier": "community",
      "config": {
        "days": {
          "type": "number",
          "label": "Lookback (days)",
          "default": 14,
          "min": 7,
          "max": 365,
          "maxCommunity": 90
        }
      }
    },
    {
      "id": "ci-run-history",
      "type": "table",
      "title": "Recent Workflow Runs",
      "description": "Chronological list of all workflow runs with status, conclusion and duration.",
      "defaultSize": "full",
      "tier": "community",
      "config": {
        "page_size": {
          "type": "number",
          "label": "Rows per page",
          "default": 25,
          "min": 10,
          "max": 100
        },
        "days": {
          "type": "number",
          "label": "Lookback (days)",
          "default": 7,
          "min": 1,
          "max": 365,
          "maxCommunity": 90
        }
      }
    }
  ],
  "defaultDashboard": {
    "name": "CI/CD & Actions",
    "layout": [
      { "widgetId": "ci-status-summary",    "width": "1/3" },
      { "widgetId": "ci-failing-workflows", "width": "2/3" },
      { "widgetId": "ci-duration-trend",    "width": "2/3" },
      { "widgetId": "ci-run-history",       "width": "full" }
    ]
  },
  "ui": {
    "navItem": {
      "label": "CI/CD",
      "icon": "⚙",
      "path": "/ci-cd",
      "order": 3
    }
  },
  "backend": {
    "syncHooks": ["onSchedule"],
    "syncModule": "plugins.builtin.ci_cd.sync"
  },
  "license": {
    "required": false
  }
}
